<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Eight Studios | Referral App</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link rel="icon" href="https://eightstudios.org/IMG_7229-removebg-preview.png">

<meta property="og:title" content="Eight Studios - Fashion Shop">
<meta property="og:description" content="You have been referred to Eight Studios, a fashion shop.">
<meta property="og:image" content="https://eightstudios.org/IMG_7229-removebg-preview.png">

<style>
body {
    margin:0;
    font-family: Arial;
    background: radial-gradient(circle at top, #0b1a24, #000);
    color:#fff;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
}

/* PHONE FRAME */
.phone {
    width:360px;
    height:720px;
    background: rgba(255,255,255,0.04);
    border:1px solid rgba(0,255,179,0.2);
    border-radius:40px;
    padding:20px;
    box-shadow: 0 0 40px rgba(0,255,179,0.08);
    backdrop-filter: blur(12px);
    position:relative;
    overflow:hidden;
}

/* TOP CENTER HOME */
.topbar {
    position:absolute;
    top:20px;
    left:0;
    right:0;
    display:flex;
    justify-content:center;
}

.home-btn {
    padding:8px 18px;
    border-radius:12px;
    border:1px solid rgba(0,255,179,0.4);
    background: rgba(0,255,179,0.08);
    color:#00ffb3;
    font-weight:bold;
    text-decoration:none;
    font-size:12px;
}

/* HEADER */
.header {
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    margin-top:60px;
    text-align:center;
}

.header img {
    width:140px;
    filter: drop-shadow(0 0 20px rgba(0,255,179,0.5));
    margin-bottom:10px;
}

.header h1 {
    font-size:20px;
    margin:0;
    color:#00ffb3;
}

.header p {
    font-size:12px;
    opacity:0.6;
    margin-top:5px;
}

/* CONTENT */
.content {
    margin-top:30px;
    text-align:center;
}

input {
    width:100%;
    padding:14px;
    border:none;
    border-radius:12px;
    text-align:center;
    font-size:12px;
}

/* BUTTON */
button {
    margin-top:12px;
    width:100%;
    padding:14px;
    border:none;
    border-radius:12px;
    background:#00ffb3;
    font-weight:bold;
    cursor:pointer;
}

/* TOAST */
.toast {
    position:absolute;
    bottom:30px;
    left:50%;
    transform:translateX(-50%);
    background: rgba(0, 255, 179, 0.15);
    border:1px solid #00ffb3;
    color:#00ffb3;
    padding:10px 16px;
    border-radius:12px;
    font-size:12px;
    opacity:0;
    transition:0.3s;
}

.toast.show {
    opacity:1;
    bottom:50px;
}
</style>
</head>

<body>

<div class="phone">

    <!-- HOME -->
    <div class="topbar">
        <a class="home-btn" href="https://eightstudios.org/">Home</a>
    </div>

    <!-- HEADER -->
    <div class="header">
        <img src="https://eightstudios.org/IMG_7229-removebg-preview.png" alt="Logo">
        <h1>Referral Link</h1>
        <p>Eight Studios Fashion Shop</p>
    </div>

    <!-- CONTENT -->
    <div class="content">

        <input id="refLink" readonly>
        <button onclick="copy()">Copy Link</button>

    </div>

    <div id="toast" class="toast">
        Copied successfully!
    </div>

</div>

<script>

// ------------------------------
// FIXED USERNAME
// ------------------------------
const userId = "EightStudios888";

// ------------------------------
// Build referral link
// ------------------------------
const referralLink =
    "https://eightstudios.org/?ref=" + userId;

document.getElementById("refLink").value = referralLink;

// ------------------------------
// Toast
// ------------------------------
function showToast(msg) {
    const toast = document.getElementById("toast");
    toast.innerText = msg;
    toast.classList.add("show");

    setTimeout(() => {
        toast.classList.remove("show");
    }, 2000);
}

// ------------------------------
// Copy link
// ------------------------------
function copy() {
    navigator.clipboard.writeText(referralLink);
    showToast("Referral link copied successfully!");
}

</script>

</body>
</html>